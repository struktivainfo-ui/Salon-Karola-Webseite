{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/leistungen.html",
      "destination": "/leistungen",
      "permanent": true
    },
    {
      "source": "/galerie",
      "destination": "/einblicke",
      "permanent": true
    },
    {
      "source": "/galerie.html",
      "destination": "/einblicke",
      "permanent": true
    },
    {
      "source": "/team",
      "destination": "/ueber-uns",
      "permanent": true
    },
    {
      "source": "/team.html",
      "destination": "/ueber-uns",
      "permanent": true
    },
    {
      "source": "/damen",
      "destination": "/leistungen#damen",
      "permanent": true
    },
    {
      "source": "/herren",
      "destination": "/leistungen#herren",
      "permanent": true
    },
    {
      "source": "/kinder",
      "destination": "/leistungen#kinder",
      "permanent": true
    },
    {
      "source": "/farbe-styling",
      "destination": "/leistungen#farbe-styling",
      "permanent": true
    },
    {
      "source": "/festliche-anlaesse",
      "destination": "/leistungen#eventfrisuren",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
